<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

  <changeSet id="20260303-pgvector-extension" author="kenzo">
    <preConditions onFail="MARK_RAN" onError="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>CREATE EXTENSION IF NOT EXISTS vector;</sql>
  </changeSet>

  <changeSet id="20260303-embedding" author="kenzo">
    <preConditions onFail="MARK_RAN" onError="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>
      ALTER TABLE geextraheerd_bezwaar ADD COLUMN IF NOT EXISTS embedding vector(1024);
    </sql>
  </changeSet>

</databaseChangeLog>
